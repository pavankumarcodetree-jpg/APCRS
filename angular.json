{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "webclient": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/webclient",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "./node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "src/assets/vendor/reey-font/stylesheet.css",
              "src/assets/vendor/animate/animate.min.css",
              "src/assets/vendor/flaticon/css/flaticon.css",
              "./node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.carousel.min.css",
              "./node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.theme.default.min.css",
              "./node_modules/slick-carousel/slick/slick-theme.css",
              "./node_modules/slick-carousel/slick/slick.css",
              "src/assets/vendor/swiper/swiper-bundle.min.css",
              "./node_modules/ngx-bootstrap/datepicker/bs-datepicker.css",
              "src/assets/css/style.css",
              "src/assets/dash/css/app-creative.min.css",
              "src/assets/dash/css/icons.min.css",
              "node_modules/ngx-toastr/toastr.css",
              "node_modules/@fancyapps/ui/dist/fancybox/fancybox.css",
              "node_modules/primeicons/primeicons.css",
              "node_modules/primeng/resources/themes/lara-light-blue/theme.css",
              "node_modules/primeng/resources/primeng.min.css",
              "@fancyapps/ui/dist/fancybox/fancybox.css",
              "src/styles.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.min.js",
              "node_modules/bootstrap/dist/js/bootstrap.bundle.js",
              "src/assets/vendor/swiper/swiper-bundle.min.js",
              "node_modules/slick-carousel/slick/slick.min.js",
              "src/assets/vendor/waypoints/jquery.waypoints.min.js",
              "src/assets/vendor/counter-up/jquery.counterup.min.js",
              "node_modules/@fancyapps/ui/dist/fancybox/fancybox.umd.js",
              "node_modules/apexcharts/dist/apexcharts.min.js",
              "src/assets/js/theme.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "7mb",
                  "maximumError": "7mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "7mb",
                  "maximumError": "7mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "webclient:build:production"
            },
            "development": {
              "buildTarget": "webclient:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "webclient:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "8bc068b2-4310-45fc-8daf-1497d8b8064b"
  }
}